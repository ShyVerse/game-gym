[wrap-git]
url = https://github.com/jrouwe/JoltPhysics.git
revision = v5.5.0
depth = 1
method = cmake
patch_directory = jolt

[cmake]
TARGET_UNIT_TESTS = false
TARGET_HELLO_WORLD = false
TARGET_PERFORMANCE_TEST = false
TARGET_SAMPLES = false
TARGET_VIEWER = false
ENABLE_ALL_WARNINGS = false

[provide]
Jolt = Jolt_dep
